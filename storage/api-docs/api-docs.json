        "/auth/google": {
            "get": {
                "tags": [
                    "Google OAuth"
                ],
                "summary": "Redirect to Google OAuth consent screen",
                "operationId": "041ae15aaa8ef4437f710361ff7480ab",
                "responses": {
                    "302": {
                        "description": "Redirects to accounts.google.com for authentication"
                    }
                }
            }
        },
        "/auth/google/callback": {
            "get": {
                "tags": [
                    "Google OAuth"
                ],
                "summary": "Handle Google OAuth callback – login or register user",
                "operationId": "1844f0d87fe4f80eb76df1e80abc7bae",
                "parameters": [
                    {
                        "name": "code",
                        "in": "query",
                        "description": "Authorization code returned by Google",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "state",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Authenticated – redirects to intended URL or dashboard"
                    },
                    "500": {
                        "description": "Google OAuth error"
                    }
                }
            }
        },
        "/oauth/authorize": {
            "get": {
                "tags": [
                    "OAuth"
                ],
                "summary": "OAuth 2.0 Authorization endpoint – shows consent screen",
                "description": "Redirects unauthenticated users to login. For already-authorized users, auto-approves and redirects to the redirect_uri with the authorization code.",
                "operationId": "1212a442203f808450fe4a03f62de893",
                "parameters": [
                    {
                        "name": "response_type",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "code"
                            ]
                        },
                        "example": "code"
                    },
                    {
                        "name": "client_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "redirect_uri",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uri"
                        },
                        "example": "https://myapp.com/callback"
                    },
                    {
                        "name": "scope",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "profile email"
                    },
                    {
                        "name": "state",
                        "in": "query",
                        "description": "CSRF protection value – must match the value in the callback",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "code_challenge",
                        "in": "query",
                        "description": "PKCE code challenge (S256)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "code_challenge_method",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "S256"
                            ]
                        }
                    },
                    {
                        "name": "prompt",
                        "in": "query",
                        "description": "Pass \"consent\" to always show the consent screen even if previously authorized",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "consent"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Consent screen (HTML/Inertia) shown to the user"
                    },
                    "302": {
                        "description": "Already authorized – redirects to redirect_uri?code=...&state=..."
                    },
                    "401": {
                        "description": "Unauthenticated – redirects to /login"
                    }
                }
            },
            "post": {
                "tags": [
                    "OAuth"
                ],
                "summary": "Approve the OAuth authorization request",
                "description": "User submits the consent form to grant access. Issues an authorization code and redirects to the client's redirect_uri.",
                "operationId": "fc9775462ce6e79af9c4b2e041602fd0",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "auth_token"
                                ],
                                "properties": {
                                    "auth_token": {
                                        "description": "Opaque token embedded in the consent form",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirects to redirect_uri?code=AUTH_CODE&state=STATE"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sessionAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "OAuth"
                ],
                "summary": "Deny the OAuth authorization request",
                "operationId": "5c353a9a409d5323bcdc03d596b8503f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "auth_token"
                                ],
                                "properties": {
                                    "auth_token": {
                                        "description": "Opaque token embedded in the consent form",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirects to redirect_uri?error=access_denied"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sessionAuth": []
                    }
                ]
            }
        },
        "/oauth/token": {
            "post": {
                "tags": [
                    "OAuth"
                ],
                "summary": "Exchange authorization code for access token",
                "description": "Token endpoint supporting authorization_code and client_credentials grants.",
                "operationId": "a25b79aa97e58a0f9afeb28a45b92372",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "required": [
                                    "grant_type",
                                    "client_id",
                                    "client_secret"
                                ],
                                "properties": {
                                    "grant_type": {
                                        "type": "string",
                                        "example": "authorization_code",
                                        "enum": [
                                            "authorization_code",
                                            "client_credentials",
                                            "refresh_token"
                                        ]
                                    },
                                    "client_id": {
                                        "type": "string",
                                        "format": "uuid"
                                    },
                                    "client_secret": {
                                        "description": "Required for confidential clients",
                                        "type": "string"
                                    },
                                    "code": {
                                        "description": "Required for authorization_code grant",
                                        "type": "string"
                                    },
                                    "redirect_uri": {
                                        "description": "Must match the one used in /oauth/authorize",
                                        "type": "string",
                                        "format": "uri"
                                    },
                                    "code_verifier": {
                                        "description": "PKCE verifier – required if code_challenge was used",
                                        "type": "string"
                                    },
                                    "refresh_token": {
                                        "description": "Required for refresh_token grant",
                                        "type": "string"
                                    },
                                    "scope": {
                                        "description": "Optional subset of original scopes for client_credentials",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token issued successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "expires_in": {
                                            "description": "Seconds until access token expiry (15 days)",
                                            "type": "integer",
                                            "example": 1296000
                                        },
                                        "access_token": {
                                            "type": "string"
                                        },
                                        "refresh_token": {
                                            "description": "Only for authorization_code grant (valid 30 days)",
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request (missing parameters, wrong grant type)"
                    },
                    "401": {
                        "description": "Invalid client credentials"
                    }
                }
            }
        },
        "/oauth/token/refresh": {
            "post": {
                "tags": [
                    "OAuth"
                ],
                "summary": "Refresh an access token (transient – same client session)",
                "operationId": "9e043d8ee453a202efa85661f5d56c51",
                "responses": {
                    "200": {
                        "description": "New access token issued"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sessionAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "OAuthClient": {
                "properties": {
                    "id": {
                        "type": "string",
