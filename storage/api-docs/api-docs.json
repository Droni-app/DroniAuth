                    "302": {
                        "description": "Secret regenerated – redirects to /clients with the new plain secret in session flash"
                    },
                    "404": {
                        "description": "Client not found or not owned by user"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sessionAuth": []
                    }
                ]
            }
        },
